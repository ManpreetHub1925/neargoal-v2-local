# Flask secret key used for session cookies and flash messages.
SECRET_KEY="change-me"

# Preferred single-variable MySQL connection string.
# Replace with your real MySQL username and password.
# Example: mysql+pymysql://neargoal_user:YOUR_REAL_PASSWORD@127.0.0.1:3306/neargoal_consulting?charset=utf8mb4
DATABASE_URL="mysql+pymysql://neargoal_user:YOUR_REAL_PASSWORD@127.0.0.1:3306/neargoal_consulting?charset=utf8mb4"

# Optional split MySQL settings if you do not want to use DATABASE_URL.
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="neargoal_user"
MYSQL_PASSWORD="YOUR_REAL_PASSWORD"
MYSQL_DATABASE="neargoal_consulting"

# Optional first admin user. If omitted, the app creates:
# ADMIN_EMAIL=admin@neargoal.com
# ADMIN_PASSWORD=Admin@123
# ADMIN_NAME=Administrator
ADMIN_EMAIL="admin@neargoal.com"
ADMIN_PASSWORD="Admin@123"
ADMIN_NAME="Administrator"
